```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/

# Build outputs
build/
dist/
target/

# Dependencies cache
node_modules/
.mypy_cache/
.pytest_cache/
```